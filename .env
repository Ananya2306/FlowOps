# ── FlowOps Environment Config ────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# API server
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# Frontend points to this URL
BACKEND_URL=http://localhost:8000

# Simulation defaults
SIM_TICK_INTERVAL_SECONDS=5
SIM_DRIFT_MAGNITUDE=0.08

# (Optional) Redis — uncomment if you swap in-memory state for Redis
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_DB=0

# (Optional) Future: Kafka for event streaming
# KAFKA_BROKER=localhost:9092
# KAFKA_TOPIC=flowops-crowd-events
